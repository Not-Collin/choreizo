# --- Required ---
# Get from @BotFather in Telegram.
TELEGRAM_BOT_TOKEN=

# Bootstraps the first admin account. Pick something long.
ADMIN_PASSWORD=

# Used for cookie signing and magic-link token signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Publicly reachable URL for the app (used in magic-link emails/DMs).
BASE_URL=http://localhost:8000

# --- Timing ---
HOUSE_TIMEZONE=America/Los_Angeles
DAILY_ASSIGNMENT_HOUR=6
HIGH_PRIORITY_REMINDER_INTERVAL_HOURS=3
ESCALATION_AFTER_HOURS=24
ADMIN_NOTIFY_AFTER_HOURS=36
ROLLOVER_HIGH_PRIORITY=true

# --- Storage ---
# Inside the container the default SQLite path is /data/choreizo.db (backed by ./data volume).
DATABASE_PATH=/data/choreizo.db
LOG_LEVEL=INFO

# --- Telegram ---
# "polling" (default) or "webhook". Use polling unless BASE_URL is reachable from the public internet.
TELEGRAM_MODE=polling

# --- Server ---
HOST=0.0.0.0
PORT=8000
